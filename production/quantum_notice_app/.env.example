# Slack incoming webhook URLs (comma or newline separated)
NOTICE_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz,https://hooks.slack.com/services/aaa/bbb/ccc

# Gemini briefing enrichment
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash
BRIEFING_SLACK_CHANNEL=C07SEMKKVSN,C08ABCDEFGH
BRIEFING_LLM_MAX_ARTICLES=5
BRIEFING_DAYS=14
BRIEFING_MAX_ITEMS=10

# Enable Playwright-backed collection for JS-heavy sites like KISA
NOTICE_USE_PLAYWRIGHT=true

# Optional: keep app/log timezone deterministic on server
TZ=Asia/Seoul
